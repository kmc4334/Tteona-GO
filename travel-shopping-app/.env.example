# ============================================================
#  떠나GO (DDUNA-GO) - Frontend 환경 변수 예시
#  파일 위치: travel-shopping-app/.env.example
#  사용법: 이 파일을 .env로 복사하고 실제 값으로 변경하세요
# ============================================================

# ─── Kakao Map API ────────────────────────────────────────
# Kakao Map JavaScript API Key
# 발급: https://developers.kakao.com/
EXPO_PUBLIC_KAKAO_MAP_API_KEY=your_kakao_map_api_key_here

# ─── Backend API 서버 ─────────────────────────────────────
# Express 백엔드 서버 주소
# 로컬: http://localhost:5000
# 네트워크: http://YOUR_IP:5000
EXPO_PUBLIC_API_BASE_URL=http://192.168.0.12:5000

# ─── Python FastAPI 서버 (AI/데이터 처리) ─────────────────
# Python FastAPI 서버 주소 (AI 추천, 데이터 분석 등)
# 로컬: http://localhost:8000
# 네트워크: http://YOUR_IP:8000
EXPO_PUBLIC_FASTAPI_BASE_URL=http://192.168.0.12:8000

# ─── OpenAI API ───────────────────────────────────────────
# OpenAI API Key (AI 일정 생성, 챗봇 등에 사용)
# 발급: https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# ─── Qdrant Vector DB ─────────────────────────────────────
# Qdrant 벡터 데이터베이스 (AI 추천 시스템에 사용)
# 발급: https://cloud.qdrant.io/
EXPO_PUBLIC_QDRANT_URL=https://your-cluster.qdrant.io
EXPO_PUBLIC_QDRANT_API_KEY=your_qdrant_api_key_here
EXPO_PUBLIC_QDRANT_COLLECTION=labeling
